{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "composite": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
      "@/prisma/*": ["./prisma/generated/prisma/*"]
    },
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0"
  },
  "tsc-alias": {
    "resolveFullPaths": true
  },
  "include": ["src", "types/**/*.d.ts", "prisma/generated/prisma/**/*"],
  "exclude": ["node_modules", "dist"]
}

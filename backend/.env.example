DATABASE_URL="postgresql://user:password@localhost:5432/promptverse?schema=public"
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SSE_WAITERS=600

# JWT Secrets (change these in production!)
ACCESS_TOKEN_SECRET=change-me-access-secret
REFRESH_TOKEN_SECRET=change-me-refresh-secret
PASSWORD_RESET_TOKEN_SECRET=change-me-password-reset-secret
EMAIL_VERIFICATION_TOKEN_SECRET=change-me-email-verification-secret

# Token Expiry
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=30d
PASSWORD_RESET_TOKEN_EXPIRY=1h
EMAIL_VERIFICATION_TOKEN_EXPIRY=1d

# Encryption
ENCRYPTION_SECRET=change-me-encryption-secret

# Logging
LOG_LEVEL=info
